<?xml version="1.0" encoding="ISO-8859-1" ?>
<scripts xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="../.gradle/scripts.xsd">

    <!--
        Para mais informações sobre a criação e utilização dos Scripts de Banco,
        consulte a documentação oficial da Sankhya em: https://developer.sankhya.com.br/docs/02_scripts
    -->

    <sql nomeTabela="FUNCAO_EXEMPLO" ordem="1" executar="SE_NAO_EXISTIR" tipoObjeto="FUNCTION" nomeObjeto="FN_SOMA">
        <oracle>
            CREATE OR REPLACE FUNCTION FN_SOMA (p_num1 IN NUMBER, p_num2 IN NUMBER)
            RETURN NUMBER
            IS
            BEGIN
            RETURN p_num1 + p_num2;
            END;
        </oracle>

        <mssql>
            CREATE FUNCTION FN_SOMA (@num1 INT, @num2 INT)
            RETURNS INT
            AS
            BEGIN
            RETURN (@num1 + @num2);
            END;
        </mssql>
    </sql>

</scripts>
