<?xml version="1.0" encoding="iso-8859-1" ?>
<metadados xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:noNamespaceSchemaLocation="../.gradle/metadados.xsd">

    <menu id="hagious.qualitymanager"
          description="QualityManager"
          icon="/$ctx/assets/icon.png">

        <!-- ═══════════════════════════════════════════════════
             MODULO: Registro de Nao Conformidades
             ISO 9001 §8.7 + §10.2
        ════════════════════════════════════════════════════ -->
        <folder id="hagious.qualitymanager.rnc"
                description="Registro de Nao Conformidades">

            <dynamicForm id="hagious.qualitymanager.rnc.consulta"
                         instance="ThgRncConsulta"
                         description="Consulta de NCs"/>

            <dynamicForm id="hagious.qualitymanager.rnc.registro"
                         instance="ThgRncRegistro"
                         description="01. Registro de NC"/>

            <dynamicForm id="hagious.qualitymanager.rnc.acaoimediata"
                         instance="ThgRncAcaoImediata"
                         description="02. Acoes Imediatas"/>

            <dynamicForm id="hagious.qualitymanager.rnc.causaraiz"
                         instance="ThgRncCausaRaiz"
                         description="03. Causa Raiz"/>

            <dynamicForm id="hagious.qualitymanager.rnc.abrangencia"
                         instance="ThgRncAbrangencia"
                         description="04. Abrangencia"/>

            <dynamicForm id="hagious.qualitymanager.rnc.acaocorretiva"
                         instance="ThgRncAcaoCorretiva"
                         description="05. Acoes Corretivas"/>

            <dynamicForm id="hagious.qualitymanager.rnc.revisaodoc"
                         instance="ThgRncRevisaoDoc"
                         description="06. Revisao de Documentos"/>

            <dynamicForm id="hagious.qualitymanager.rnc.risco"
                         instance="ThgRncRisco"
                         description="07. Riscos e Oportunidades"/>

            <dynamicForm id="hagious.qualitymanager.rnc.implementacao"
                         instance="ThgRncImplementacao"
                         description="08. Implementacao"/>

            <dynamicForm id="hagious.qualitymanager.rnc.liberacao"
                         instance="ThgRncLiberacao"
                         description="09. Liberacao de Produto"/>

            <dynamicForm id="hagious.qualitymanager.rnc.eficacia"
                         instance="ThgRncEficacia"
                         description="10. Verificacao de Eficacia"/>

        </folder>

        <!-- ═══════════════════════════════════════════════════
             MODULO: Fornecedores
             ISO 9001 §8.4
        ════════════════════════════════════════════════════ -->
        <folder id="hagious.qualitymanager.forn"
                description="Fornecedores">

            <dynamicForm id="hagious.qualitymanager.forn.consulta"
                         instance="ThgFornConsulta"
                         description="Consulta de Fornecedores"/>

            <dynamicForm id="hagious.qualitymanager.forn.qualificacao"
                         instance="ThgFornQualificacao"
                         description="Qualificacao"/>

            <dynamicForm id="hagious.qualitymanager.forn.criterios"
                         instance="ThgFornCriterio"
                         description="Criterios de Avaliacao"/>

            <dynamicForm id="hagious.qualitymanager.forn.questionario"
                         instance="ThgFornQuestionario"
                         description="Questionarios"/>

        </folder>

        <!-- ═══════════════════════════════════════════════════
             MODULO: Documentos
             ISO 9001 §7.5
        ════════════════════════════════════════════════════ -->
        <folder id="hagious.qualitymanager.doc"
                description="Documentos">

            <dynamicForm id="hagious.qualitymanager.doc.controle"
                         instance="ThgDocControle"
                         description="Controle de Documentos"/>

        </folder>

        <!-- ═══════════════════════════════════════════════════
             MODULO: Gestao de Mudancas
             ISO 9001 §6.3 + §8.5.6
        ════════════════════════════════════════════════════ -->
        <folder id="hagious.qualitymanager.gm"
                description="Gestao de Mudancas">

            <dynamicForm id="hagious.qualitymanager.gm.cadastro"
                         instance="ThgGmCadastro"
                         description="Cadastro de Mudancas"/>

        </folder>

        <!-- ═══════════════════════════════════════════════════
             MODULO: Auditoria
             ISO 9001 §9.2
        ════════════════════════════════════════════════════ -->
        <folder id="hagious.qualitymanager.aud"
                description="Auditoria">

            <dynamicForm id="hagious.qualitymanager.aud.programa"
                         instance="ThgAudPrograma"
                         description="Programa de Auditoria"/>

            <dynamicForm id="hagious.qualitymanager.aud.registro"
                         instance="ThgAudRegistro"
                         description="Registro de Auditoria"/>

            <dynamicForm id="hagious.qualitymanager.aud.auditores"
                         instance="ThgAudAuditor"
                         description="Auditores"/>

        </folder>

        <!-- ═══════════════════════════════════════════════════
             MODULO: Indicadores
             ISO 9001 §9.1 + §9.3
        ════════════════════════════════════════════════════ -->
        <folder id="hagious.qualitymanager.ind"
                description="Indicadores">

            <dynamicForm id="hagious.qualitymanager.ind.indicador"
                         instance="ThgIndIndicador"
                         description="Indicadores"/>

            <dynamicForm id="hagious.qualitymanager.ind.ata"
                         instance="ThgAcrAta"
                         description="Analise Critica"/>

        </folder>

        <!-- ═══════════════════════════════════════════════════
             Configuracao e Parametrizacao
        ════════════════════════════════════════════════════ -->
        <folder id="hagious.qualitymanager.config"
                description="Configuracao">

            <dynamicForm id="hagious.qualitymanager.config.parametros"
                         instance="ThgConfig"
                         description="Configuracao"/>

            <dynamicForm id="hagious.qualitymanager.config.prioridades"
                         instance="ThgDomPrioridade"
                         description="Prioridades"/>

            <dynamicForm id="hagious.qualitymanager.config.fases"
                         instance="ThgRncFase"
                         description="Fases RNC"/>

            <dynamicForm id="hagious.qualitymanager.config.log"
                         instance="ThgLogAuditoria"
                         description="Log de Auditoria"/>

        </folder>

    </menu>

</metadados>
